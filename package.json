{
  "name": "@takk/bayestruth",
  "version": "1.0.0",
  "description": "BayesTruth: Bayesian trust and reputation scoring for Massive Intelligence (IM) agents, tools, MCP servers, and skills. A zero-runtime-dependency, TypeScript-first library that treats every tool call as Bernoulli evidence and maintains an exact Beta-Bernoulli conjugate posterior per subject, so a trust score is a calibrated number with a credible interval that respects the sample size, not a heuristic threshold. Closed-form online updates with zero inference latency, customizable priors per category, optional time-decay for stale evidence, Thompson-sampling bandit selection between competing tools, a tamper-evident hash-chained audit trail for compliance, and a node-free core that runs in Node, edge runtimes, and the browser, with optional peers @takk/keymesh, @takk/modelchain, @takk/behavioralai, @takk/noeticos, @takk/racs, @takk/gaptime, @takk/krikos, @takk/mcpcustoms, @takk/alkaline, @takk/tokenforecast, @takk/agenticstash and @takk/automend.",
  "keywords": [
    "bayesian",
    "trust-scoring",
    "reputation",
    "beta-bernoulli",
    "conjugate-prior",
    "credible-interval",
    "calibration",
    "thompson-sampling",
    "multi-armed-bandit",
    "uncertainty-quantification",
    "agent-reliability",
    "tool-trust",
    "mcp",
    "compliance",
    "edge",
    "openai",
    "anthropic",
    "llm",
    "zero-dependency",
    "typescript"
  ],
  "homepage": "https://github.com/davccavalcante/bayestruth",
  "bugs": {
